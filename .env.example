ANTHROPIC_API_KEY=your-key-here
# Optional — defaults to claude-sonnet-4-5 (Claude Sonnet 4.5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Redis — caches analysis results (same log + hint skips Claude)
REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_TTL_SECONDS=604800
# ANALYSIS_CACHE_VERSION=1

# GitHub OAuth (production) — leave unset for local dev (auto dev user)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# JWT_SECRET=
# PUBLIC_BASE_URL=http://localhost:8000
# AUTH_COOKIE_SECURE=false
# AUTH_DISABLED=1

# Database — PostgreSQL in production (Terraform RDS); SQLite when unset
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/debugpilot

# Log uploads — S3 on AWS (set in Helm); local dir when UPLOADS_S3_BUCKET unset
# UPLOADS_S3_BUCKET=debugpilot-log-uploads-ACCOUNT_ID
# UPLOADS_LOCAL_DIR=/tmp/debugpilot-uploads
# UPLOADS_MAX_BYTES=524288
