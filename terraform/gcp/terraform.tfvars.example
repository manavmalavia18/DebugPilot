gcp_project_id       = "your-gcp-project-id"
gcp_region           = "us-central1"
# Skip us-central1-c if you hit GCE_STOCKOUT; or set gcp_zone = "us-central1-a" for zonal cluster
node_locations       = ["us-central1-a", "us-central1-b"]
machine_type         = "e2-small"
cloudflare_api_token = "YOUR_CLOUDFLARE_API_TOKEN"
argocd_password      = "debugpilot123"
# argocd_github_webhook_secret = "openssl rand -hex 32" — must match GitHub repo webhook secret
api_image_tag        = "latest"
